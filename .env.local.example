# Optionnel : clé API Anthropic pour activer le vrai tuteur AI côté serveur.
# Sinon, la clé peut être saisie dans la page Paramètres du site.
ANTHROPIC_API_KEY=

# Requis pour les comptes et la progression persistante (Supabase Cloud).
# À récupérer dans Project Settings → API sur supabase.com.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé serveur uniquement (jamais exposée au client) — utilisée pour la suppression de compte.
SUPABASE_SERVICE_ROLE_KEY=
